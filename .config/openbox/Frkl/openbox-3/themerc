#============================================================
# Frkl openbox theme inspired by theme below
#
#  Inspired by "The Dracula openbox theme"
#============================================================


# Menu
menu.border.width: 6
menu.overlap.x:    -6
menu.overlap.y:    3

menu.border.color:              #ffffff
menu.separator.color:           #dddddd

menu.title.bg:                  flat solid
menu.title.bg.color:            #ffffff
menu.title.text.color:          #000000
menu.title.text.justify:        Center

menu.items.bg:                  flat solid
menu.items.bg.color:            #ffffff
menu.items.border.width:        3
menu.items.border.color:        #ffffff

menu.items.text.color:          #000000
menu.items.disabled.text.color: #888888

menu.items.active.bg:           flat solid
menu.items.active.bg.color:     #ffffff
menu.items.active.text.color:   #333333

# Active window
window.active.border.color:                           #eeeeee

window.active.title.bg:                               solid flat
window.active.title.bg.color:                         #ffffff
window.active.title.separator.color:                  #ffffff
window.active.title.separator.width:                  3
window.active.text.justify:                           center

window.active.label.bg:                               parentrelative
window.active.label.text.color:                       #121212

window.active.handle.bg:                              flat solid
window.active.handle.bg.color:                        #ffffff

window.active.grip.bg:                                flat solid
window.active.grip.bg.color:                          #ffffff

window.active.button.unpressed.bg:                    parentrelative
window.active.button.unpressed.bg.color:              #282A36

window.active.button.iconify.unpressed.image.color:   #F1FA8C
window.active.button.iconify.pressed.image.color:     #F1FA8C
window.active.button.iconify.hover.image.color:       #F1FA8C

window.active.button.max.unpressed.image.color:       #50FA7B
window.active.button.max.pressed.image.color:         #50FA7B
window.active.button.max.hover.image.color:           #50FA7B

window.active.button.close.unpressed.image.color:     #FF5555
window.active.button.close.pressed.image.color:       #FF5555
window.active.button.close.hover.image.color:         #FF5555

window.active.button.shade.unpressed.image.color:     #FF79C6
window.active.button.shade.pressed.image.color:       #FF79C6
window.active.button.shade.hover.image.color:         #FF79C6

window.active.button.desk.unpressed.image.color:      #8BE9FD
window.active.button.desk.pressed.image.color:        #8BE9FD
window.active.button.desk.hover.image.color:          #8BE9FD

window.active.button.pressed.bg:                      parentrelative
window.active.button.pressed.bg.color:                #282A36

window.active.button.disabled.bg:                     parentrelative
window.active.button.disabled.bg.color:               #282A36
window.active.button.disabled.image.color:            #282A36

window.active.button.toggled.bg:                      parentrelative
window.active.button.toggled.image.color:             #BD93F9

window.active.button.toggled.pressed.bg:              parentrelative
window.active.button.toggled.pressed.image.color:     #BD93F9

# Inactive window
window.inactive.border.color:                         #eeeeee

window.inactive.title.bg:                             flat solid
window.inactive.title.bg.color:                       #eeeeee
window.inactive.title.separator.color:                #eeeeee
window.inactive.text.justify:                         center

window.inactive.label.bg:                             parentrelative
window.inactive.label.text.color:                     #323232

window.inactive.handle.bg:                            flat solid
window.inactive.handle.bg.color:                      #eeeeee

window.inactive.grip.bg:                              flat solid
window.inactive.grip.bg.color:                        #eeeeee

window.inactive.button.unpressed.bg:                  parentrelative
window.inactive.button.unpressed.bg.color:            #282A36

window.inactive.button.iconify.unpressed.image.color: #4D4D4D
window.inactive.button.iconify.pressed.image.color:   #F1FA8C
window.inactive.button.iconify.hover.image.color:     #F1FA8C

window.inactive.button.max.unpressed.image.color:     #4D4D4D
window.inactive.button.max.pressed.image.color:       #50FA7B
window.inactive.button.max.hover.image.color:         #50FA7B

window.inactive.button.close.unpressed.image.color:   #4D4D4D
window.inactive.button.close.pressed.image.color:     #FF5555
window.inactive.button.close.hover.image.color:       #FF5555

window.inactive.button.shade.unpressed.image.color:   #4D4D4D
window.inactive.button.shade.pressed.image.color:     #FF79C6
window.inactive.button.shade.hover.image.color:       #FF79C6

window.inactive.button.desk.unpressed.image.color:    #4D4D4D
window.inactive.button.desk.pressed.image.color:      #8BE9FD
window.inactive.button.desk.hover.image.color:        #8BE9FD

window.inactive.button.pressed.bg:                    flat solid
window.inactive.button.pressed.bg.color:              #BD93F9

window.inactive.button.disabled.bg:                   flat solid
window.inactive.button.disabled.bg.color:             #282A36
window.inactive.button.disabled.image.color:          #282A36

window.inactive.button.toggled.bg:                    parentrelative
window.inactive.button.toggled.image.color:           #BD93F9

window.inactive.button.toggled.pressed.bg:            parentrelative
window.inactive.button.toggled.pressed.image.color:   #BD93F9

# OSD
osd.border.width:                    3
osd.border.color:                    #eeeeee

osd.bg:                              flat solid
osd.bg.color:                        #eeeeee
osd.label.bg:                        flat solid
osd.label.bg.color:                  #eeeeee
osd.label.text.color:                #121212

osd.hilight.bg:                      flat solid
osd.hilight.bg.color:                #000000

osd.unhilight.bg:                    flat solid
osd.unhilight.bg.color:              #555555

osd.button.unpressed.bg:             flat border
osd.button.unpressed.bg.color:       #4D4D4D
osd.button.unpressed.*.border.color: #eeeeee

osd.button.pressed.bg:               flat border
osd.button.pressed.bg.color:         #4D4D4D
osd.button.pressed.*.border.color:   #eeeeee

osd.button.focused.bg:               flat solid border
osd.button.focused.bg.color:         #eeeeee
osd.button.focused.*.border.color:   #eeeeee

osd.button.focused.box.color:        #BD93F9

# Fonts
window.active.label.text.font:       shadow=n
window.inactive.label.text.font:     shadow=n
menu.items.font:                     shadow=n
menu.title.text.font:                shadow=n

# Everything else
border.width:                0
padding.width:               14
padding.height:              8
window.handle.width:         3
window.client.padding.width: 0
window.label.text.justify:   center
