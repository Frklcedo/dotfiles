{
    "php" : {
        "prefix": "php",
        "body": [
            "<?php ${1:} ?>"
        ]
    },
    "phpe" : {
        "prefix": "phpe",
        "body": [
            "<?= ${1:} ?>"
        ]
    },
    "phpif" : {
        "prefix": "phpif",
        "body": [
            "<?php if(${1:condition}) { ?>",
            "${2:}",
            "<?php }${3:} ?>"
        ]
    },
    "phpifelse" : {
        "prefix": "phpifelse",
        "body": [
            "<?php if(${1:condition}) { ?>",
            "${2:}",
            "<?php } else { ?>",
            "${3:}",
            "<?php }${4:} ?>"
        ]
    },
    "phpelseif" : {
        "prefix": "phpelseif",
        "body": [
            "<?php if(${1:condition}) { ?>",
            "${2:}",
            "<?php } elseif(${3:condition}) { ?>",
            "${4:}",
            "<?php } else { ?>",
            "${5:}",
            "<?php }${6:} ?>"
        ]
    },
    "phpwhile" : {
        "prefix": "phpwhile",
        "body": [
            "<?php while(${1:condition}) { ?>",
            "${2:}",
            "<?php }${3:} ?>"
        ]
    },
    "phpforeach" : {
        "prefix": "phpforeach",
        "body": [
            "<?php foreach(${1:data} as ${2:key} => ${3:value}) { ?>",
            "${4:}",
            "<?php }${5:} ?>"
        ]
    }
}
